<!DOCTYPE html>
<html>

<head>
<meta charset="UTF-8">
<title>Best Cities Tournament</title>

<style>

body{
font-family:Arial;
background:#0f172a;
color:white;
padding:20px;
margin:0;
}

h1{
text-align:center;
margin-bottom:5px;
}

#roundLabel{
text-align:center;
font-size:20px;
color:#93c5fd;
margin-bottom:6px;
font-weight:bold;
}

#countdown{
text-align:center;
font-size:42px;
margin-bottom:40px;
color:#38bdf8;
font-weight:bold;
}


/* BRACKET */

.bracket{
display:grid;
grid-template-columns: repeat(7, 180px);
justify-content:center;
gap:35px;
align-items:start;
}


/* ROUNDS */

.round{
display:flex;
flex-direction:column;
}


/* MATCH BOX */

.match{
background:#1e293b;
padding:8px;
border-radius:8px;
width:170px;
margin:14px 0;
}

.team{
display:flex;
justify-content:space-between;
padding:6px;
cursor:pointer;
}

.team:hover{
color:#38bdf8;
}

.closed{
opacity:0.5;
cursor:default;
}


/* ALIGNMENT */

.qf-left{
margin-top:90px;
}

.qf-right{
margin-top:90px;
}

.qf-left .match{
margin-bottom:160px;
}

.qf-right .match{
margin-bottom:160px;
}

.sf-left{
margin-top:200px;
}

.sf-right{
margin-top:200px;
}

.final{
margin-top:120px;
}


/* TROPHY */

.trophy{
display:flex;
align-items:center;
justify-content:center;
font-size:60px;
margin-top:260px;
}


/* MOBILE */

@media (max-width:900px){

.bracket{
display:flex;
flex-direction:column;
align-items:center;
}

.round{
margin-bottom:30px;
}

.trophy{
margin-top:20px;
}

}

</style>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

</head>

<body>

<h1>Best Cities in Europe</h1>

<div id="roundLabel">Loading round...</div>
<div id="countdown">Loading...</div>


<div class="bracket">

<div class="round" id="round16-left"></div>

<div class="round qf-left" id="qf-left"></div>

<div class="round sf-left" id="sf-left"></div>

<div class="round final" id="final"></div>

<div class="trophy">🏆</div>

<div class="round sf-right" id="sf-right"></div>

<div class="round qf-right" id="qf-right"></div>

<div class="round" id="round16-right"></div>

</div>


<script>

const supabaseClient = window.supabase.createClient(
"https://okaprbdbtnyiutztibcs.supabase.co",
"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9rYXByYmRidG55aXV0enRpYmNzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMzMDgyNjgsImV4cCI6MjA4ODg4NDI2OH0.8tfmypajrsLVbrD3-PUwkJvrM1h9aQ8UN2IP3btoNLE"
)

const ROUND_LABELS={
round16:"ROUND OF 16",
qf:"QUARTERFINALS",
sf:"SEMIFINALS",
final:"FINAL"
}


async function updateTimer(){

const {data}=await supabaseClient.rpc("get_active_round_info")

if(!data || data.length===0){
document.getElementById("countdown").innerText="Tournament finished"
return
}

const row=data[0]

let secs=Math.max(0,row.remaining_seconds)

let m=Math.floor(secs/60)
let s=secs%60

let mm=String(m).padStart(2,"0")
let ss=String(s).padStart(2,"0")

document.getElementById("roundLabel").innerText=ROUND_LABELS[row.round]
document.getElementById("countdown").innerText=`${mm}:${ss}`

if(secs===0){
await supabaseClient.rpc("advance_tournament")
}

}



function createMatch(match,votes){

const box=document.createElement("div")
box.className="match"

let teamA=match.team_a||"TBD"
let teamB=match.team_b||"TBD"

let votesA=votes.filter(v=>v.match_id===match.id && v.choice===teamA).length
let votesB=votes.filter(v=>v.match_id===match.id && v.choice===teamB).length

let total=votesA+votesB

let pA=total?Math.round(votesA/total*100):50
let pB=total?Math.round(votesB/total*100):50

let classA="team"
let classB="team"

if(match.status!=="open"){
classA+=" closed"
classB+=" closed"
}

box.innerHTML=`

<div class="${classA}" onclick="openDuel('${match.id}','${match.status}')">
${teamA} <span>${pA}%</span>
</div>

<div class="${classB}" onclick="openDuel('${match.id}','${match.status}')">
${teamB} <span>${pB}%</span>
</div>

`

return box

}


function openDuel(matchId,status){

if(status!=="open"){
alert("Match closed")
return
}

window.location.href="/duel.html?match_id="+matchId

}


async function loadBracket(){

const {data:matches}=await supabaseClient.from("matches").select("*")
const {data:votes}=await supabaseClient.from("votes").select("*")

const round16=matches.filter(m=>m.round==="round16")
const qf=matches.filter(m=>m.round==="qf")
const sf=matches.filter(m=>m.round==="sf")
const final=matches.filter(m=>m.round==="final")

document.getElementById("round16-left").innerHTML=""
document.getElementById("round16-right").innerHTML=""
document.getElementById("qf-left").innerHTML=""
document.getElementById("qf-right").innerHTML=""
document.getElementById("sf-left").innerHTML=""
document.getElementById("sf-right").innerHTML=""
document.getElementById("final").innerHTML=""

round16.slice(0,4).forEach(m=>{
document.getElementById("round16-left").appendChild(createMatch(m,votes))
})

round16.slice(4,8).forEach(m=>{
document.getElementById("round16-right").appendChild(createMatch(m,votes))
})

qf.slice(0,2).forEach(m=>{
document.getElementById("qf-left").appendChild(createMatch(m,votes))
})

qf.slice(2,4).forEach(m=>{
document.getElementById("qf-right").appendChild(createMatch(m,votes))
})

sf.slice(0,1).forEach(m=>{
document.getElementById("sf-left").appendChild(createMatch(m,votes))
})

sf.slice(1,2).forEach(m=>{
document.getElementById("sf-right").appendChild(createMatch(m,votes))
})

final.forEach(m=>{
document.getElementById("final").appendChild(createMatch(m,votes))
})

}

updateTimer()
loadBracket()

setInterval(updateTimer,1000)
setInterval(loadBracket,3000)

</script>

</body>
</html>
